# ─────────────────────────────────────────────────────────────────────────────
# .env.example
# Copy to .env and fill in real values. Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="AI Test Automation Platform"
APP_ENV=development          # development | staging | production
DEBUG=true
SECRET_KEY=your-secret-key-at-least-32-chars
API_V1_PREFIX=/api/v1

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/testai_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── AI / LLM ──────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your-google-gemini-api-key
LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=8192
EMBEDDING_MODEL=models/text-embedding-004

# ── Jira ──────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_API_TOKEN=your-jira-api-token
JIRA_USER_EMAIL=your@email.com
JIRA_PROJECT_KEY=ESHOP

# ── Confluence ────────────────────────────────────────────────────────────────
CONFLUENCE_BASE_URL=https://your-org.atlassian.net/wiki
CONFLUENCE_API_TOKEN=your-confluence-api-token
CONFLUENCE_USER_EMAIL=your@email.com

# ── Zephyr Scale ──────────────────────────────────────────────────────────────
ZEPHYR_BASE_URL=https://api.zephyrscale.smartbear.com/v2
ZEPHYR_API_TOKEN=your-zephyr-api-token
ZEPHYR_PROJECT_KEY=ESHOP

# ── Harness ───────────────────────────────────────────────────────────────────
HARNESS_BASE_URL=https://app.harness.io
HARNESS_API_KEY=your-harness-api-key
HARNESS_ACCOUNT_ID=your-account-id
HARNESS_ORG_ID=your-org-id
HARNESS_PROJECT_ID=your-project-id
HARNESS_PIPELINE_ID=your-pipeline-id

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json          # json | text
